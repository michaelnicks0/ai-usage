digraph {
  compound=true
  graph [fontname="Arial", rankdir=LR, ranksep=1.0, nodesep=1.0]
  node [fontname="Arial", shape=box, margin="0.4,0.3"]
  edge [fontname="Arial"]
  label=<<br /><font point-size="34">Container View: ai-usage</font><br /><font point-size="24">C2: runtime containers and local data store for ai-usage.</font>>

  1 [id=1,shape=rect, label=<<font point-size="34">Operator</font><br /><font point-size="19">[Person]</font><br /><br /><font point-size="24">Runs ai-usage from a shell to<br />inspect provider balances,<br />spend, subscription quotas,<br />token usage, and local<br />history.</font>>, style=filled, color="#2563eb", fillcolor="#dbeafe", fontcolor="#111827"]
  14 [id=14,shape=cylinder, label=<<font point-size="34">Local credential<br />files</font><br /><font point-size="19">[Software System]</font><br /><br /><font point-size="24">Credential and OAuth state<br />outside the repo:<br />~/.hermes/.env,<br />~/.config/vastai/vast_api_key,<br />~/.hermes/auth.json,<br />~/.hermes/auth/google_oauth.json,<br />~/.claude/.credentials.json,<br />~/.claude.json, and<br />~/.claude/stats-cache.json.</font>>, style=filled, color="#d97706", fillcolor="#fef3c7", fontcolor="#111827"]
  15 [id=15,shape=rect, label=<<font point-size="34">Local developer CLIs</font><br /><font point-size="19">[Software System]</font><br /><br /><font point-size="24">Codex CLI app-server/login and<br />Claude Code CLI refresh paths<br />used for subscription quota<br />and OAuth refresh behavior.</font>>, style=filled, color="#9333ea", fillcolor="#f3e8ff", fontcolor="#111827"]
  16 [id=16,shape=rect, label=<<font point-size="34">Provider HTTP APIs</font><br /><font point-size="19">[Software System]</font><br /><br /><font point-size="24">External APIs for DeepSeek,<br />xAI, Vast.ai, Exa, X Console,<br />Anthropic OAuth usage, Nous<br />Portal, Google OAuth, and<br />Google Cloud Code quota data.</font>>, style=filled, color="#9333ea", fillcolor="#f3e8ff", fontcolor="#111827"]
  17 [id=17,shape=rect, label=<<font point-size="34">Terminal / calling<br />process</font><br /><font point-size="19">[Software System]</font><br /><br /><font point-size="24">Receives stdout table or JSON<br />output from ai-usage.</font>>, style=filled, color="#9333ea", fillcolor="#f3e8ff", fontcolor="#111827"]

  subgraph cluster_2 {
    margin=25
    label=<<font point-size="24"><br />ai-usage</font><br /><font point-size="19">[Software System]</font>>
    labelloc=b
    color="#444444"
    fontcolor="#444444"
    fillcolor="#444444"

    13 [id=13,shape=cylinder, label=<<font point-size="34">Snapshot history<br />database</font><br /><font point-size="19">[Container: SQLite WAL file at ~/.hermes/ai-usage.db]</font><br /><br /><font point-size="24">Stores normalized provider<br />snapshots for --history<br />queries; raw provider payloads<br />are not stored.</font>>, style=filled, color="#d97706", fillcolor="#fef3c7", fontcolor="#111827"]
    3 [id=3,shape=rect, label=<<font point-size="34">CLI process</font><br /><font point-size="19">[Container: Python 3.10+ CLI]</font><br /><br /><font point-size="24">Argparse-driven command<br />process exposed as<br />ai_usage.cli:main and the<br />ai-usage console script.</font>>, style=filled, color="#0284c7", fillcolor="#e0f2fe", fontcolor="#111827"]
  }

  1 -> 3 [id=19, label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="white"><TR><TD><font point-size="24">Invokes ai-usage commands</font><br /><font point-size="19">[shell]</font></TD></TR></TABLE>>, style="dashed", color="#475569", fontcolor="#475569"]
  3 -> 14 [id=24, label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="white"><TR><TD><font point-size="24">Reads credentials and<br />OAuth state</font><br /><font point-size="19">[filesystem]</font></TD></TR></TABLE>>, style="dashed", color="#475569", fontcolor="#475569"]
  3 -> 15 [id=25, label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="white"><TR><TD><font point-size="24">Starts Codex and Claude<br />helper commands when<br />required</font><br /><font point-size="19">[subprocess]</font></TD></TR></TABLE>>, style="dashed", color="#475569", fontcolor="#475569"]
  3 -> 16 [id=26, label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="white"><TR><TD><font point-size="24">Calls provider APIs<br />through adapters</font><br /><font point-size="19">[HTTPS]</font></TD></TR></TABLE>>, style="dashed", color="#475569", fontcolor="#475569"]
  3 -> 13 [id=27, label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="white"><TR><TD><font point-size="24">Writes and reads snapshots</font><br /><font point-size="19">[sqlite3]</font></TD></TR></TABLE>>, style="dashed", color="#475569", fontcolor="#475569"]
  3 -> 17 [id=28, label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="white"><TR><TD><font point-size="24">Prints table or JSON<br />reports</font><br /><font point-size="19">[stdout]</font></TD></TR></TABLE>>, style="dashed", color="#475569", fontcolor="#475569"]

}