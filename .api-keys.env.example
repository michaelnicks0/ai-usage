# AI Usage Watcher — API Keys
# Copy this to .api-keys.env and fill in your keys:
#   cp .api-keys.env.example .api-keys.env

# xAI API key (used for key verification; credit check uses browser cookie)
XAI_API_KEY=xai-...

# DeepSeek API key (used for balance check)
DEEPSEEK_API_KEY=sk-...

# Vast.ai API key (from https://cloud.vast.ai/manage-keys/)
VASTAI_API_KEY=...

# Optional: manual xAI console session token (if browser cookie extraction fails)
# XAI_CONSOLE_TOKEN=
