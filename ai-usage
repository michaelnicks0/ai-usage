def query_history(provider=None, limit=10):
    """Return rows from the snapshots table, newest first."""
    conn = _db()
    if provider:
        rows = conn.execute(
            "SELECT timestamp, provider, balance, spend, "
            "tokens_input, tokens_cached, tokens_output "
            "FROM snapshots WHERE provider=? "
            "ORDER BY timestamp DESC LIMIT ?",
            (provider, limit)).fetchall()
    else:
        rows = conn.execute(
            "SELECT timestamp, provider, balance, spend, "
            "tokens_input, tokens_cached, tokens_output "
            "FROM snapshots "
            "ORDER BY timestamp DESC LIMIT ?",
            (limit * len(ALL_PROVIDERS),)).fetchall()
    conn.close()
    return rows


def render_history(provider=None, limit=10):
    rows = query_history(provider, limit)
    if not rows:
        label = f" for {PROVIDER_NAMES.get(provider, provider)}" if provider else ""
        print(f"No history found{label}. Run ai-usage first to collect snapshots.")
        return

    prefix = f"History — {PROVIDER_NAMES.get(provider, provider)}" if provider else "History — all providers"
    print(f"{prefix}  ({len(rows)} rows)\n")

    # Build column data: (ts_display, provider, balance, spend, in_hit, in_miss, out, total)
    cols = []
    for r in rows:
        ts, prov, bal, spd, inp, cached, outp = r
        ts_short = ts.replace("T", " ").split("+")[0].split("Z")[0][:16]
        total = (cached or 0) + (inp or 0) + (outp or 0)
        cols.append((ts_short, prov, bal, spd, cached or 0, inp or 0, outp or 0, total))

    headers = ["Timestamp", "Balance", "Spend", "In(Hit)", "In(Miss)", "Out", "Total"]
    if not provider:
        headers.insert(1, "Provider")

    # Column widths
    col_w = [len(h) for h in headers]
    for row in cols:
        ts, prov, bal, spd, cached, inp, outp, total = row
        vals = [ts, fmt_amt(bal), fmt_amt(spd),
                fmt_tok(cached), fmt_tok(inp), fmt_tok(outp), fmt_tok(total)]
        if not provider:
            vals.insert(1, prov)
        for i, v in enumerate(vals):
            col_w[i] = max(col_w[i], len(v))

    print("  ".join(h.center(col_w[i]) for i, h in enumerate(headers)))
    print("─" * (sum(col_w) + 2 * (len(headers) - 1)))
    for row in cols:
        ts, prov_name, bal, spd, cached, inp, outp, total = row
        vals = [ts, fmt_amt(bal), fmt_amt(spd),
                fmt_tok(cached), fmt_tok(inp), fmt_tok(outp), fmt_tok(total)]
        if not provider:
            vals.insert(1, prov_name)
        line = "  ".join(v.rjust(col_w[i]) for i, v in enumerate(vals))
        print(line)
    print()


def render_history_json(provider=None, limit=10):
    rows = query_history(provider, limit)
    out = []
    for r in rows:
        ts, prov, bal, spd, inp, cached, outp = r
        out.append({
            "timestamp": ts,
            "provider": prov,
            "balance": round(bal, 2) if bal is not None else None,
            "spend": round(spd, 2) if spd is not None else None,
            "tokens_cached": cached or 0,
            "tokens_input": inp or 0,
            "tokens_output": outp or 0,
        })
    print(json.dumps(out, indent=2))


