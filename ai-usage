            cd = _fmt_codex_countdown(weekly.get("resets_at"))
            print(f"               Resets in {cd}")
        print()

    # ── Claude Code detail section ──
    for i, pname in enumerate(filtered_names):
        d = filtered_data[i]
        cl = d.get("claude_extra")
        if not cl:
            continue
        print(f"Claude Code Details  ({cl.get('plan_type', 'unknown')})")
        print("─" * 48)
        sess = cl.get("session")
        if sess:
            pct = sess["remaining_pct"]
            bar_w = 30
