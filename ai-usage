PROVIDER_NAMES = {"deepseek": "DeepSeek", "xai": "xAI", "vastai": "Vast.ai", "exa": "Exa", "x": "X API", "codex": "Codex", "claude": "Claude Code", "nous": "Nous"}

def fmt_amt(n):
    if n is None: return "     —"
    return f"${n:,.2f}"

def fmt_tok(n):
    if n == 0: return "        —"
    return f"{n:>9,}"


def _select(providers):
    ds   = get_deepseek()
    xai  = get_xai()
    va   = get_vastai()
    exa  = get_exa()
    x    = get_x()
    cx   = get_codex()
    cl   = get_claude()
    nous = get_nous()

    # Persist snapshot for every provider (even if data is empty)
    data_map = {"deepseek": ds, "xai": xai, "vastai": va, "exa": exa, "x": x, "codex": cx, "claude": cl, "nous": nous}
    for k in ALL_PROVIDERS:
        if k in providers:
            save_snapshot(k, data_map[k])

    return [PROVIDER_NAMES[k] for k in ALL_PROVIDERS], [ds, xai, va, exa, x, cx, cl, nous]


def _token_pcts(d):
    total_in = d["cached"] + d["input"]
    hit = round(d["cached"] / total_in * 100, 1) if total_in > 0 else 0
    miss = round(d["input"] / total_in * 100, 1) if total_in > 0 else 0
    return hit, miss


def _model_entry(d):
    hit, miss = _token_pcts(d)
    return {
        "tokens_in_hit": d["cached"],
        "tokens_in_hit_percentage": hit,
        "tokens_in_miss": d["input"],
        "tokens_in_miss_percentage": miss,
        "tokens_out": d["output"],
        "tokens_total": d["cached"] + d["input"] + d["output"],
    }


