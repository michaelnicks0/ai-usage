#!/usr/bin/env python3
"""ai-usage — cross-provider balance + token usage (v2).

This is a thin wrapper around the ai_usage package.
For development, use `pip install -e .` from the repo root.
"""

import sys
import os

# Ensure the src directory is on the path when run directly
_repo_root = os.path.dirname(os.path.abspath(__file__))
_src = os.path.join(_repo_root, "src")
if _src not in sys.path:
    sys.path.insert(0, _src)

from ai_usage.cli import main

if __name__ == "__main__":
    sys.exit(main())
