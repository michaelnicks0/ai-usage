    table_names = [n for n, k in zip(filtered_names, filtered_keys) if k not in SUBSCRIPTION_PROVIDERS]
    table_data  = [d for d, k in zip(filtered_data, filtered_keys) if k not in SUBSCRIPTION_PROVIDERS]

