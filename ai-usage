        if k not in providers:
            continue
        d = {"deepseek": data[0], "xai": data[1], "vastai": data[2], "exa": data[3], "x": data[4], "codex": data[5], "claude": data[6], "nous": data[7]}[k]

        # Codex: only output the codex block — no balance/spend/token fluff
        if k == "codex":
            cx = d.get("codex_extra")
            if cx:
                sub_out["codex"] = {
                    "plan_type": cx.get("plan_type"),
                    "session": cx.get("session"),
                    "weekly": cx.get("weekly"),
                }
            continue

        # Only include token fields for LLM providers
        if k in TOKEN_PROVIDERS:
            entry = _model_entry(d)
        else:
            entry = {}

        entry["balance"] = round(d["balance"], 2) if d["balance"] is not None else None
        entry["period_spend"] = round(d["spent"], 2) if d["spent"] is not None else None

        # Claude: include rate-limit windows like Codex
        if k == "claude":
            cl = d.get("claude_extra")
            if cl:
                entry["plan_type"] = cl.get("plan_type")
                entry["session"] = cl.get("session")
                entry["weekly"] = cl.get("weekly")

        # Nous: include subscription details
        if k == "nous":
            nx = d.get("nous_extra")
            if nx:
                entry["plan_type"] = nx.get("plan_type")
                entry["monthly_charge"] = nx.get("monthly_charge")
                entry["credits_remaining"] = nx.get("credits_remaining")
                entry["current_period_end"] = nx.get("current_period_end")

        if show_model and d["models"]:
            entry["models"] = OrderedDict()
            for mname, md in d["models"].items():
                if k == "claude":
                    entry["models"][mname] = {
                        "input_tokens": md["input"],
                        "cached_tokens": md["cached"],
                        "output_tokens": md["output"],
                        "total_tokens": md["input"] + md["cached"] + md["output"],
                    }
                else:
                    entry["models"][mname] = _model_entry(md)

        if k in SUBSCRIPTION_PROVIDERS:
            sub_out[key_map[k].lower()] = entry
        else:
            api_out[key_map[k].lower()] = entry

    out = OrderedDict()
    if api_out:
        out["api"] = api_out
    if sub_out:
        out["subscription"] = sub_out
    print(json.dumps(out, indent=2))


def _fmt_codex_countdown(ts):
    """Format time until reset for Codex display."""
    if ts is None:
        return "—"
    delta = datetime.fromtimestamp(ts, tz=timezone.utc) - datetime.now(timezone.utc)
    if delta.total_seconds() <= 0:
        return "now"
    days = delta.days
    hours, rem = divmod(delta.seconds, 3600)
    mins = rem // 60
    parts = []
    if days:
        parts.append(f"{days}d")
    if hours:
        parts.append(f"{hours}h")
    if mins or not parts:
        parts.append(f"{mins}m")
    return "".join(parts)


