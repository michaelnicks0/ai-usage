DB_PATH = os.path.join(_hermes_dir, "ai-usage.db")


def _db():
    """Return a connection to the SQLite DB, creating tables if needed."""
    conn = sqlite3.connect(DB_PATH)
    conn.execute("PRAGMA journal_mode=WAL")
    conn.execute("""
        CREATE TABLE IF NOT EXISTS snapshots (
            id        INTEGER PRIMARY KEY AUTOINCREMENT,
            timestamp TEXT    NOT NULL,
            provider  TEXT    NOT NULL,
            balance   REAL,
            spend     REAL,
            tokens_input  INTEGER DEFAULT 0,
            tokens_cached INTEGER DEFAULT 0,
            tokens_output INTEGER DEFAULT 0
        )
    """)
    conn.execute("""
        CREATE INDEX IF NOT EXISTS idx_provider_ts
        ON snapshots(provider, timestamp)
    """)
    return conn


def save_snapshot(provider, data):
    """Insert one provider's current data into the snapshots table."""
    conn = _db()
    now = datetime.now(timezone.utc).isoformat(timespec="seconds")
    conn.execute(
        "INSERT INTO snapshots (timestamp, provider, balance, spend, "
        "tokens_input, tokens_cached, tokens_output) "
        "VALUES (?,?,?,?,?,?,?)",
        (now, provider,
         data.get("balance"), data.get("spent"),
         data.get("input", 0), data.get("cached", 0), data.get("output", 0)))
    conn.commit()
    conn.close()


def get(url, headers=None, timeout=10):
    hdrs = {"User-Agent": "ai-usage/1.0"}
    if headers:
        hdrs.update(headers)
    req = Request(url, headers=hdrs)
    with urlopen(req, timeout=timeout) as r:
        return json.loads(r.read())


def _m():
    return {"input": 0, "cached": 0, "output": 0}


# ── DeepSeek ─────────────────────────────────────────────────────────────

def get_deepseek():
    data = {"balance": None, "input": 0, "cached": 0, "output": 0,
            "spent": None, "models": OrderedDict()}
    now = datetime.now()

    if DEEPSEEK_KEY:
        try:
            r = get("https://api.deepseek.com/user/balance",
                    {"Authorization": f"Bearer {DEEPSEEK_KEY}"})
            for b in r.get("balance_infos", []):
                if b.get("currency") == "USD":
                    data["balance"] = float(b["total_balance"])
        except Exception:
            pass

    if DEEPSEEK_AUTH:
        try:
            r = get(
                f"https://platform.deepseek.com/api/v0/usage/amount"
                f"?month={now.month}&year={now.year}",
                {"Authorization": f"Bearer {DEEPSEEK_AUTH}",
                 "x-app-version": "20240425.0"})
            for m in r["data"]["biz_data"]["total"]:
                name = m["model"]
                md = _m()
                for u in m["usage"]:
                    amt = int(u["amount"])
                    t = u["type"]
                    if t == "PROMPT_CACHE_MISS_TOKEN":
                        data["input"] += amt; md["input"] += amt
                    elif t == "PROMPT_CACHE_HIT_TOKEN":
                        data["cached"] += amt; md["cached"] += amt
                    elif t == "RESPONSE_TOKEN":
                        data["output"] += amt; md["output"] += amt
                data["models"][name] = md
            data["spent"] = (
                data["input"] / 1_000_000 * DS_PRICE_CACHE_MISS +
                data["cached"] / 1_000_000 * DS_PRICE_CACHE_HIT +
                data["output"] / 1_000_000 * DS_PRICE_OUTPUT
            )
        except Exception:
            pass

    return data


# ── xAI ──────────────────────────────────────────────────────────────────

def get_xai():
    data = {"balance": None, "input": 0, "cached": 0, "output": 0,
            "spent": None, "models": OrderedDict()}
    if not (XAI_MGMT_KEY and XAI_TEAM_ID):
        return data

    headers = {"Authorization": f"Bearer {XAI_MGMT_KEY}"}
    base = f"https://management-api.x.ai/v1/billing/teams/{XAI_TEAM_ID}"

    try:
        r = get(f"{base}/prepaid/balance", headers)
        data["balance"] = abs(float(r.get("total", {}).get("val", "0"))) / 100
    except Exception:
        pass

    try:
        r = get(f"{base}/postpaid/invoice/preview", headers)
        inv = r.get("coreInvoice", {})
        for line in inv.get("lines", []):
            name = line.get("description", "unknown")
            ut = line.get("unitType", "")
            nu = int(line.get("numUnits", "0"))
            md = data["models"].setdefault(name, _m())
            if "Cached" in ut:
                data["cached"] += nu; md["cached"] += nu
            elif "Prompt" in ut:
                data["input"] += nu; md["input"] += nu
            elif "Completion" in ut:
                data["output"] += nu; md["output"] += nu
        data["spent"] = float(inv.get("totalWithCorr", {}).get("val", "0")) / 100
    except Exception:
        pass

    return data


# ── Vast.ai ──────────────────────────────────────────────────────────────

def get_vastai():
    data = {"balance": None, "input": 0, "cached": 0, "output": 0,
            "spent": None, "models": OrderedDict()}
    if not VASTAI_KEY:
        return data
    try:
        r = get("https://console.vast.ai/api/v0/users/current/",
                {"Authorization": f"Bearer {VASTAI_KEY}"})
        data["balance"] = float(r.get("credit", 0))
    except Exception:
        pass

    try:
        now = datetime.now()
        month_start = int(datetime(now.year, now.month, 1).timestamp())
        if now.month == 12:
            month_end = int(datetime(now.year + 1, 1, 1).timestamp())
        else:
            month_end = int(datetime(now.year, now.month + 1, 1).timestamp())

        filters = json.dumps({"day": {"gte": month_start, "lte": month_end}}, separators=(",", ":"))
        url = (f"https://cloud.vast.ai/api/v0/charges/?"
               f"select_filters={quote(filters)}&latest_first=true&limit=50")
        charges = get(url, {"Authorization": f"Bearer {VASTAI_KEY}"})
        spent = sum(float(r.get("amount", 0)) for r in charges.get("results", []))
        if spent > 0:
            data["spent"] = spent
    except Exception:
        pass

    return data


# ── Exa ──────────────────────────────────────────────────────────────────

def get_exa():
    data = {"balance": None, "input": 0, "cached": 0, "output": 0,
            "spent": None, "models": OrderedDict()}
    if not (EXA_SERVICE_KEY or EXA_SESSION_TOKEN):
        return data

    # 1. Balance via dashboard session token (optional, same pattern as DeepSeek)
    if EXA_SESSION_TOKEN:
        try:
            r = get("https://dashboard.exa.ai/api/get-orb-balance",
                    {"Cookie": f"next-auth.session-token={EXA_SESSION_TOKEN}",
                     "User-Agent": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) Chrome/147.0.0.0 Safari/537.36"})
            data["balance"] = float(r.get("orbCreditsInCents", 0)) / 100
        except Exception:
            pass

    if not EXA_SERVICE_KEY:
        return data

    headers = {"x-api-key": EXA_SERVICE_KEY}

    # 2. Discover API key ID
    try:
        keys_resp = get("https://admin-api.exa.ai/team-management/api-keys", headers)
        api_keys = keys_resp.get("apiKeys", [])
        if not api_keys:
            return data
        key_id = api_keys[0]["id"]
    except Exception:
        return data

    # 3. Fetch current month's usage
    try:
        now = datetime.now()
        start = f"{now.year}-{now.month:02d}-01T00:00:00Z"
        if now.month == 12:
            end = f"{now.year + 1}-01-01T00:00:00Z"
        else:
            end = f"{now.year}-{now.month + 1:02d}-01T00:00:00Z"
        params = f"start_date={start}&end_date={end}"
        url = (f"https://admin-api.exa.ai/team-management/api-keys/"
               f"{key_id}/usage?{params}")
        usage = get(url, headers)
        data["spent"] = float(usage.get("total_cost_usd", 0))
    except Exception:
        pass

    return data


# ── X (Twitter) ──────────────────────────────────────────────────────────

def get_x():
    data = {"balance": None, "input": 0, "cached": 0, "output": 0,
            "spent": None, "models": OrderedDict()}
    if not (X_API_AUTH_TOKEN and X_API_CT0 and X_API_ACCOUNT_ID):
        return data

    cookie = f"auth_token={X_API_AUTH_TOKEN}; ct0={X_API_CT0}"
    headers = {"x-csrf-token": X_API_CT0, "Cookie": cookie}
    base = "https://console.x.com/api"

    try:
        r = get(f"{base}/accounts/{X_API_ACCOUNT_ID}/credits", headers)
        data["balance"] = float(r["credits"]["balance"])
    except Exception:
        pass

    # fetch pricing once — reused for spend calculation
    pricing = {}
    try:
        r = get(f"{base}/credits/pricing", headers)
        pricing = r.get("eventTypePricing", {})
    except Exception:
        pass

    try:
        r = get(
            f"{base}/accounts/{X_API_ACCOUNT_ID}/usage"
            f"?interval=30days&groupBy=eventType",
            headers)
        usage_data = r.get("usage", {})
        spend = 0.0
        for app_id, app in usage_data.items():
            if app_id == "_total" or not isinstance(app, dict):
                continue
            groups = app.get("groups", {})
            for event_type, evt in groups.items():
                count = int(evt.get("usage", 0))
                if count > 0:
                    data["models"][event_type] = {"input": count, "cached": 0, "output": 0}
                    if event_type in pricing:
                        spend += count * pricing[event_type]
        if spend > 0:
            data["spent"] = round(spend, 2)
    except Exception:
        pass

    return data


# ── Codex (OpenAI) ──────────────────────────────────────────────────────

def get_codex():
    """Fetch Codex quota via CLI app-server JSON-RPC.

    Requires `codex login` (OAuth token at ~/.codex/auth.json).
    Returns session/weekly windows + credits in codex_extra, plus
    standard balance/token dict for table compatibility.
    """
    data = {"balance": None, "input": 0, "cached": 0, "output": 0,
            "spent": None, "models": OrderedDict(), "codex_extra": None}

    try:
        proc = subprocess.Popen(
            ["codex", "app-server"],
            stdin=subprocess.PIPE, stdout=subprocess.PIPE,
            stderr=subprocess.PIPE, text=True, bufsize=1)
    except FileNotFoundError:
        return data

    pending = {}
    lock = threading.Lock()

    def reader():
        for line in iter(proc.stdout.readline, ""):
            line = line.strip()
            if not line:
                continue
            try:
                msg = json.loads(line)
            except json.JSONDecodeError:
                continue
            rid = msg.get("id")
            with lock:
                if rid in pending:
                    evt, container = pending.pop(rid)
                    container["msg"] = msg
                    evt.set()

    t = threading.Thread(target=reader, daemon=True)
    t.start()

    def rpc(method, params=None, rpc_timeout=10):
        if params is None:
            params = {}
        req_id = int(time.time() * 1000) % 100000
        payload = json.dumps({"jsonrpc": "2.0", "id": req_id,
                              "method": method, "params": params}) + "\n"
        evt = threading.Event()
        container = {}
        with lock:
            pending[req_id] = (evt, container)
        try:
            proc.stdin.write(payload)
            proc.stdin.flush()
        except (BrokenPipeError, OSError):
            with lock:
                pending.pop(req_id, None)
            return None
        if not evt.wait(timeout=rpc_timeout):
            with lock:
                pending.pop(req_id, None)
            return None
        msg = container.get("msg", {})
        if "error" in msg:
            return None
        return msg.get("result")

    try:
        rpc("initialize", {"clientInfo": {"name": "ai-usage", "version": "1.0.0"}})
        result = rpc("account/rateLimits/read")
        if result:
            rl = result.get("rateLimits", result)
            p = rl.get("primary")
            s = rl.get("secondary")
            cr = rl.get("credits", {})
            extra = {"plan_type": rl.get("planType", "unknown")}
            if p:
                extra["session"] = {
                    "used_pct": p.get("usedPercent", 0),
                    "remaining_pct": 100 - p.get("usedPercent", 0),
                    "duration_mins": p.get("windowDurationMins", 0),
                    "resets_at": p.get("resetsAt"),
                }
            if s:
                extra["weekly"] = {
                    "used_pct": s.get("usedPercent", 0),
                    "remaining_pct": 100 - s.get("usedPercent", 0),
                    "duration_mins": s.get("windowDurationMins", 0),
                    "resets_at": s.get("resetsAt"),
                }
            extra["credits"] = {
                "balance": cr.get("balance", "0"),
                "has_credits": cr.get("hasCredits", False),
            }
            data["codex_extra"] = extra
            # Map credits → balance for table
            try:
                data["balance"] = float(extra["credits"]["balance"])
            except (ValueError, TypeError):
                data["balance"] = 0
    except Exception:
        pass
    finally:
        try:
            proc.stdin.close()
        except Exception:
            pass
        try:
            proc.wait(timeout=3)
        except Exception:
            proc.kill()

    return data


# ── Claude Code (Anthropic) ──────────────────────────────────────────────

def get_claude():
    """Fetch Claude Code usage via OAuth API + local stats files.

    Auto-refreshes the OAuth token by running `claude` briefly, then hits
    Anthropic's OAuth usage endpoint for session/weekly rate limit windows.
    Falls back to local ~/.claude.json and ~/.claude/stats-cache.json for
    token/cost data.
    """
    data = {"balance": None, "input": 0, "cached": 0, "output": 0,
            "spent": None, "models": OrderedDict(), "claude_extra": None}

    creds_path = os.path.expanduser("~/.claude/.credentials.json")

    # ── OAuth rate limit API ──
    if os.path.exists(creds_path):
        try:
            with open(creds_path) as f:
                creds = json.load(f).get("claudeAiOauth", {})
            token = creds.get("accessToken", "")
            if token:
                usage = get("https://api.anthropic.com/api/oauth/usage",
                           {"Authorization": f"Bearer {token}",
                            "anthropic-beta": "oauth-2025-04-20"})
                extra = {"plan_type": creds.get("subscriptionType", "unknown")}
                fh = usage.get("five_hour", {})
                sd = usage.get("seven_day", {})
                if fh:
                    util = fh.get("utilization", 0)
                    pct = round(util) if util is not None else 0
                    resets = fh.get("resets_at")
                    extra["session"] = {
                        "used_pct": pct,
                        "remaining_pct": max(0, 100 - pct),
                        "resets_at": (int(datetime.fromisoformat(resets).timestamp())
                                      if resets else None),
                    }
                if sd:
                    util = sd.get("utilization", 0)
                    pct = round(util) if util is not None else 0
                    resets = sd.get("resets_at")
                    extra["weekly"] = {
                        "used_pct": pct,
                        "remaining_pct": max(0, 100 - pct),
                        "resets_at": (int(datetime.fromisoformat(resets).timestamp())
                                      if resets else None),
                    }
                data["claude_extra"] = extra
        except Exception:
            pass

    # ── Local file fallback: subscribe info if API didn't populate extra ──
    claude_json = os.path.expanduser("~/.claude.json")
    if os.path.exists(claude_json):
        try:
            with open(claude_json) as f:
                config = json.load(f)
            total_cost = 0.0
            for _proj_path, proj in config.get("projects", {}).items():
                total_cost += proj.get("lastCost", 0)
                lmu = proj.get("lastModelUsage", {})
                for model_name, mu in lmu.items():
                    md = data["models"].setdefault(model_name, _m())
                    md["input"] += mu.get("inputTokens", 0)
                    md["cached"] += (mu.get("cacheReadInputTokens", 0) +
                                    mu.get("cacheCreationInputTokens", 0))
                    md["output"] += mu.get("outputTokens", 0)
            if total_cost > 0:
                data["spent"] = round(total_cost, 4)
            # Fallback extra if API didn't return rate limits
            if not data["claude_extra"]:
                oauth = config.get("oauthAccount", {})
                data["claude_extra"] = {
                    "plan_type": oauth.get("billingType", "unknown"),
                }
        except Exception:
            pass

    # ── Aggregated model usage from stats-cache ──
    stats_path = os.path.expanduser("~/.claude/stats-cache.json")
    if os.path.exists(stats_path):
        try:
            with open(stats_path) as f:
                stats = json.load(f)
            model_usage = stats.get("modelUsage", {})
            for model_name, mu in model_usage.items():
                inp = mu.get("inputTokens", 0)
                cached = (mu.get("cacheReadInputTokens", 0) +
                          mu.get("cacheCreationInputTokens", 0))
                out = mu.get("outputTokens", 0)
                md = data["models"].setdefault(model_name, _m())
                if inp > md["input"]: md["input"] = inp
                if cached > md["cached"]: md["cached"] = cached
                if out > md["output"]: md["output"] = out
            data["input"] = sum(m["input"] for m in data["models"].values())
            data["cached"] = sum(m["cached"] for m in data["models"].values())
            data["output"] = sum(m["output"] for m in data["models"].values())
        except Exception:
            pass

    return data


# ── Nous Research ─────────────────────────────────────────────────────────

def get_nous():
    """Fetch Nous Portal subscription/credit info via OAuth account API.

    Nous Research offers subscription credits ($20+/mo) that deplete as
    you use managed services (web search, image gen, TTS, browser).
    No per-request token tracking — credits are the unit of consumption.
    """
    data = {"balance": None, "input": 0, "cached": 0, "output": 0,
            "spent": None, "models": OrderedDict(), "nous_extra": None}

    if NOUS_TOKEN:
        try:
            r = get("https://portal.nousresearch.com/api/oauth/account",
                    {"Authorization": f"Bearer {NOUS_TOKEN}"})
            sub = r.get("subscription", {})
            credits = sub.get("credits_remaining")
            charge = sub.get("monthly_charge")
            period_end = sub.get("current_period_end")

            data["balance"] = round(float(credits), 2) if credits is not None else None
            data["spent"] = round(float(charge), 2) if charge is not None else None

            data["nous_extra"] = {
                "plan_type": sub.get("plan", "unknown"),
                "tier": sub.get("tier"),
                "monthly_charge": data["spent"],
                "credits_remaining": data["balance"],
                "current_period_end": period_end,
            }
        except Exception:
            pass

    return data


