#!/usr/bin/env python3
"""Normalized cross-provider balance + token usage view.

Default:  balance, tokens, spend
--model:  adds model column
"""

import sys, json, os, argparse
from datetime import datetime
from urllib.request import Request, urlopen
from urllib.parse import quote
from urllib.error import URLError

# ── credentials (auto-resolve from env or config files) ──────────────────

def _read_env_file(path):
    """Parse KEY=value from a .env-style file."""
    if not os.path.exists(path):
        return {}
    d = {}
    with open(path) as f:
        for line in f:
            line = line.strip()
            if line and not line.startswith("#") and "=" in line:
                k, v = line.split("=", 1)
                d[k.strip()] = v.strip().strip('"').strip("'")
    return d

_hermes_env = _read_env_file(os.path.expanduser("~/.hermes/.env"))

DEEPSEEK_KEY  = os.environ.get("DEEPSEEK_API_KEY", _hermes_env.get("DEEPSEEK_API_KEY", ""))
DEEPSEEK_AUTH = os.environ.get("DEEPSEEK_AUTH_TOKEN", _hermes_env.get("DEEPSEEK_AUTH_TOKEN", ""))
XAI_MGMT_KEY  = os.environ.get("XAI_MANAGEMENT_KEY", _hermes_env.get("XAI_MANAGEMENT_KEY", ""))
XAI_TEAM_ID   = os.environ.get("XAI_TEAM_ID", _hermes_env.get("XAI_TEAM_ID", ""))
_vast_file    = os.path.expanduser("~/.config/vastai/vast_api_key")
_vast_file_key = open(_vast_file).read().strip() if os.path.exists(_vast_file) else ""
VASTAI_KEY    = (os.environ.get("VASTAI_API_KEY", _hermes_env.get("VASTAI_API_KEY", ""))
                 or _vast_file_key)

# DeepSeek pricing per 1M tokens (deepseek-v4-pro, 75% promo)
DS_PRICE_CACHE_HIT  = 0.003625
DS_PRICE_CACHE_MISS = 0.435
DS_PRICE_OUTPUT     = 0.87


def get(url, headers=None, timeout=10):
    req = Request(url, headers=headers or {})
    with urlopen(req, timeout=timeout) as r:
        return json.loads(r.read())


# ── DeepSeek ─────────────────────────────────────────────────────────────

def get_deepseek():
    data = {"balance": None, "input": 0, "cached": 0, "output": 0,
            "spent": None, "model": ""}
    now = datetime.now()

    # balance
    if DEEPSEEK_KEY:
        try:
            r = get("https://api.deepseek.com/user/balance",
                    {"Authorization": f"Bearer {DEEPSEEK_KEY}"})
            for b in r.get("balance_infos", []):
                if b.get("currency") == "USD":
                    data["balance"] = float(b["total_balance"])
        except Exception:
            pass

    # usage (internal platform API)
    if DEEPSEEK_AUTH:
        try:
            r = get(
                f"https://platform.deepseek.com/api/v0/usage/amount"
                f"?month={now.month}&year={now.year}",
                {"Authorization": f"Bearer {DEEPSEEK_AUTH}",
                 "x-app-version": "20240425.0"})
            total = r["data"]["biz_data"]["total"]
            for m in total:
                for u in m["usage"]:
                    amt = int(u["amount"])
                    if amt == 0:
                        continue
                    t = u["type"]
                    if t == "PROMPT_CACHE_MISS_TOKEN":
                        data["input"] += amt
                    elif t == "PROMPT_CACHE_HIT_TOKEN":
                        data["cached"] += amt
                    elif t == "RESPONSE_TOKEN":
                        data["output"] += amt
                    data["model"] = m["model"]
            data["spent"] = (
                data["input"] / 1_000_000 * DS_PRICE_CACHE_MISS +
                data["cached"] / 1_000_000 * DS_PRICE_CACHE_HIT +
                data["output"] / 1_000_000 * DS_PRICE_OUTPUT
            )
        except Exception:
            pass

    return data


# ── xAI ──────────────────────────────────────────────────────────────────

def get_xai():
    data = {"balance": None, "input": 0, "cached": 0, "output": 0,
            "spent": None, "model": ""}
    if not (XAI_MGMT_KEY and XAI_TEAM_ID):
        return data

    headers = {"Authorization": f"Bearer {XAI_MGMT_KEY}"}
    base = f"https://management-api.x.ai/v1/billing/teams/{XAI_TEAM_ID}"

    # balance
    try:
        r = get(f"{base}/prepaid/balance", headers)
        total = r.get("total", {}).get("val", "0")
        data["balance"] = abs(float(total)) / 100
    except Exception:
        pass

    # tokens + spend (invoice preview)
    try:
        r = get(f"{base}/postpaid/invoice/preview", headers)
        inv = r.get("coreInvoice", {})
        for line in inv.get("lines", []):
            ut = line.get("unitType", "")
            nu = int(line.get("numUnits", "0"))
            if "Cached" in ut:
                data["cached"] += nu
            elif "Prompt" in ut:
                data["input"] += nu
            elif "Completion" in ut:
                data["output"] += nu
            data["model"] = line.get("description", "")
        data["spent"] = float(inv.get("totalWithCorr", {}).get("val", "0")) / 100
    except Exception:
        pass

    return data


# ── Vast.ai ──────────────────────────────────────────────────────────────

def get_vastai():
    data = {"balance": None, "input": 0, "cached": 0, "output": 0,
            "spent": None, "model": ""}
    if not VASTAI_KEY:
        return data
    try:
        r = get("https://console.vast.ai/api/v0/users/current/",
                {"Authorization": f"Bearer {VASTAI_KEY}"})
        data["balance"] = float(r.get("credit", 0))
    except Exception:
        pass

    # sum current month's charges
    try:
        now = datetime.now()
        month_start = int(datetime(now.year, now.month, 1).timestamp())
        if now.month == 12:
            month_end = int(datetime(now.year + 1, 1, 1).timestamp())
        else:
            month_end = int(datetime(now.year, now.month + 1, 1).timestamp())

        filters = json.dumps({"day": {"gte": month_start, "lte": month_end}}, separators=(",", ":"))
        url = (f"https://cloud.vast.ai/api/v0/charges/?"
               f"select_filters={quote(filters)}&latest_first=true&limit=50")
        charges = get(url, {"Authorization": f"Bearer {VASTAI_KEY}"})
        spent = 0.0
        for r in charges.get("results", []):
            spent += float(r.get("amount", 0))
        if spent > 0:
            data["spent"] = spent
    except Exception:
        pass

    return data


# ── display ──────────────────────────────────────────────────────────────

PROVIDER_NAMES = {"deepseek": "DeepSeek", "xai": "xAI", "vastai": "Vast.ai"}

def fmt_amt(n):
    if n is None:
        return "     —"
    return f"${n:,.2f}"

def fmt_tok(n):
    if n == 0:
        return "        —"
    return f"{n:>9,}"

def _select(providers, keys):
    ds  = get_deepseek()
    xai = get_xai()
    va  = get_vastai()
    lookup = {"deepseek": ds, "xai": xai, "vastai": va}
    names = [PROVIDER_NAMES[k] for k in keys]
    data  = [lookup[k] for k in keys]
    return names, data


def render_json(providers, show_model=False):
    names, data = _select(providers, ["deepseek", "xai", "vastai"])
    key_map = {"deepseek": "DeepSeek", "xai": "xAI", "vastai": "Vast.ai"}
    lookup = {"deepseek": data[0], "xai": data[1], "vastai": data[2]}
    out = {}
    for k in ["deepseek", "xai", "vastai"]:
        if k not in providers:
            continue
        d = lookup[k]
        total_in = d["input"] + d["cached"]
        hit_pct = round(d["cached"] / total_in * 100, 1) if total_in > 0 else 0
        miss_pct = round(d["input"] / total_in * 100, 1) if total_in > 0 else 0
        entry = {
            "balance": d["balance"],
            "period_spend": round(d["spent"], 2) if d["spent"] is not None else None,
            "tokens_in_hit": d["cached"],
            "tokens_in_hit_percentage": hit_pct,
            "tokens_in_miss": d["input"],
            "tokens_in_miss_percentage": miss_pct,
            "tokens_out": d["output"],
            "tokens_total": total_in + d["output"],
        }
        if show_model:
            entry["model"] = d["model"] or None
        out[key_map[k].lower()] = entry
    print(json.dumps(out, indent=2))


def render_table(providers, show_model=False):
    names, data = _select(providers, ["deepseek", "xai", "vastai"])
    key_map = {"deepseek": "DeepSeek", "xai": "xAI", "vastai": "Vast.ai"}

    filtered_names = []
    filtered_data = []
    for k in ["deepseek", "xai", "vastai"]:
        if k in providers:
            filtered_names.append(key_map[k])
            filtered_data.append({"deepseek": data[0], "xai": data[1], "vastai": data[2]}[k])

    if not filtered_names:
        return

    rows = [
        ("Account Balance",          lambda d: fmt_amt(d["balance"])),
        ("Month / Period Spend",     lambda d: fmt_amt(d["spent"])),
        ("Tokens In (Cache Hit)",    lambda d: fmt_tok(d["cached"])),
        ("Tokens In (Cache Miss)",   lambda d: fmt_tok(d["input"])),
        ("Tokens Out",               lambda d: fmt_tok(d["output"])),
        ("Tokens Total",             lambda d: fmt_tok(d["input"] + d["cached"] + d["output"])),
    ]
    if show_model:
        rows.append(("Model", lambda d: d["model"] or "—"))

    dw = 20
    label_w = max(len(r[0]) for r in rows)
    row_data = [[fn(d) for d in filtered_data] for _, fn in rows]

    print(f"{'':{label_w}}  " + "  ".join(n.center(dw) for n in filtered_names))
    print(f"{'─'*label_w}──" + "──".join("─"*dw for _ in filtered_names))

    for (label, _), vals in zip(rows, row_data):
        line = "  ".join(v.rjust(dw) for v in vals)
        print(f"{label:<{label_w}}  {line}")

    print()


ALL_PROVIDERS = ["deepseek", "xai", "vastai"]


# ── cli ──────────────────────────────────────────────────────────────────

if __name__ == "__main__":
    if len(sys.argv) > 1 and sys.argv[1] == "help":
        sys.argv[1] = "--help"

    p = argparse.ArgumentParser(description="Cross-provider balance + token usage")
    p.add_argument("--model", "-m", action="store_true", help="Show model breakdown")
    p.add_argument("--json", "-j", action="store_true", help="Output as JSON")
    p.add_argument("--provider", "-p", default=",".join(ALL_PROVIDERS),
                   help=f"Comma-separated providers: {','.join(ALL_PROVIDERS)}")
    args = p.parse_args()

    providers = [s.strip().lower() for s in args.provider.split(",") if s.strip()]
    for prov in providers:
        if prov not in ALL_PROVIDERS:
            print(f"Unknown provider: {prov}. Choices: {','.join(ALL_PROVIDERS)}", file=sys.stderr)
            sys.exit(1)

    if args.json:
        render_json(providers, show_model=args.model)
    else:
        render_table(providers, show_model=args.model)
