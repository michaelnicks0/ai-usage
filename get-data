#!/usr/bin/env python3
"""Normalized cross-provider balance + token usage view.

Default:  balance, tokens, spend
-m:       per-model token breakdown
"""

import sys, json, os, argparse
from collections import OrderedDict
from datetime import datetime
from urllib.request import Request, urlopen
from urllib.parse import quote
from urllib.error import URLError

# ── credentials ──────────────────────────────────────────────────────────

def _read_env_file(path):
    if not os.path.exists(path):
        return {}
    d = {}
    with open(path) as f:
        for line in f:
            line = line.strip()
            if line and not line.startswith("#") and "=" in line:
                k, v = line.split("=", 1)
                d[k.strip()] = v.strip().strip('"').strip("'")
    return d

_hermes_env = _read_env_file(os.path.expanduser("~/.hermes/.env"))

DEEPSEEK_KEY  = os.environ.get("DEEPSEEK_API_KEY", _hermes_env.get("DEEPSEEK_API_KEY", ""))
DEEPSEEK_AUTH = os.environ.get("DEEPSEEK_AUTH_TOKEN", _hermes_env.get("DEEPSEEK_AUTH_TOKEN", ""))
XAI_MGMT_KEY  = os.environ.get("XAI_MANAGEMENT_KEY", _hermes_env.get("XAI_MANAGEMENT_KEY", ""))
XAI_TEAM_ID   = os.environ.get("XAI_TEAM_ID", _hermes_env.get("XAI_TEAM_ID", ""))
_vast_file    = os.path.expanduser("~/.config/vastai/vast_api_key")
_vast_file_key = open(_vast_file).read().strip() if os.path.exists(_vast_file) else ""
VASTAI_KEY    = (os.environ.get("VASTAI_API_KEY", _hermes_env.get("VASTAI_API_KEY", ""))
                 or _vast_file_key)
EXA_SERVICE_KEY = os.environ.get("EXA_SERVICE_KEY", _hermes_env.get("EXA_SERVICE_KEY", ""))

DS_PRICE_CACHE_HIT  = 0.003625
DS_PRICE_CACHE_MISS = 0.435
DS_PRICE_OUTPUT     = 0.87


def get(url, headers=None, timeout=10):
    hdrs = {"User-Agent": "ai-usage-tool/1.0"}
    if headers:
        hdrs.update(headers)
    req = Request(url, headers=hdrs)
    with urlopen(req, timeout=timeout) as r:
        return json.loads(r.read())


def _m():
    return {"input": 0, "cached": 0, "output": 0}


# ── DeepSeek ─────────────────────────────────────────────────────────────

def get_deepseek():
    data = {"balance": None, "input": 0, "cached": 0, "output": 0,
            "spent": None, "models": OrderedDict()}
    now = datetime.now()

    if DEEPSEEK_KEY:
        try:
            r = get("https://api.deepseek.com/user/balance",
                    {"Authorization": f"Bearer {DEEPSEEK_KEY}"})
            for b in r.get("balance_infos", []):
                if b.get("currency") == "USD":
                    data["balance"] = float(b["total_balance"])
        except Exception:
            pass

    if DEEPSEEK_AUTH:
        try:
            r = get(
                f"https://platform.deepseek.com/api/v0/usage/amount"
                f"?month={now.month}&year={now.year}",
                {"Authorization": f"Bearer {DEEPSEEK_AUTH}",
                 "x-app-version": "20240425.0"})
            for m in r["data"]["biz_data"]["total"]:
                name = m["model"]
                md = _m()
                for u in m["usage"]:
                    amt = int(u["amount"])
                    t = u["type"]
                    if t == "PROMPT_CACHE_MISS_TOKEN":
                        data["input"] += amt; md["input"] += amt
                    elif t == "PROMPT_CACHE_HIT_TOKEN":
                        data["cached"] += amt; md["cached"] += amt
                    elif t == "RESPONSE_TOKEN":
                        data["output"] += amt; md["output"] += amt
                data["models"][name] = md
            data["spent"] = (
                data["input"] / 1_000_000 * DS_PRICE_CACHE_MISS +
                data["cached"] / 1_000_000 * DS_PRICE_CACHE_HIT +
                data["output"] / 1_000_000 * DS_PRICE_OUTPUT
            )
        except Exception:
            pass

    return data


# ── xAI ──────────────────────────────────────────────────────────────────

def get_xai():
    data = {"balance": None, "input": 0, "cached": 0, "output": 0,
            "spent": None, "models": OrderedDict()}
    if not (XAI_MGMT_KEY and XAI_TEAM_ID):
        return data

    headers = {"Authorization": f"Bearer {XAI_MGMT_KEY}"}
    base = f"https://management-api.x.ai/v1/billing/teams/{XAI_TEAM_ID}"

    try:
        r = get(f"{base}/prepaid/balance", headers)
        data["balance"] = abs(float(r.get("total", {}).get("val", "0"))) / 100
    except Exception:
        pass

    try:
        r = get(f"{base}/postpaid/invoice/preview", headers)
        inv = r.get("coreInvoice", {})
        for line in inv.get("lines", []):
            name = line.get("description", "unknown")
            ut = line.get("unitType", "")
            nu = int(line.get("numUnits", "0"))
            md = data["models"].setdefault(name, _m())
            if "Cached" in ut:
                data["cached"] += nu; md["cached"] += nu
            elif "Prompt" in ut:
                data["input"] += nu; md["input"] += nu
            elif "Completion" in ut:
                data["output"] += nu; md["output"] += nu
        data["spent"] = float(inv.get("totalWithCorr", {}).get("val", "0")) / 100
    except Exception:
        pass

    return data


# ── Vast.ai ──────────────────────────────────────────────────────────────

def get_vastai():
    data = {"balance": None, "input": 0, "cached": 0, "output": 0,
            "spent": None, "models": OrderedDict()}
    if not VASTAI_KEY:
        return data
    try:
        r = get("https://console.vast.ai/api/v0/users/current/",
                {"Authorization": f"Bearer {VASTAI_KEY}"})
        data["balance"] = float(r.get("credit", 0))
    except Exception:
        pass

    try:
        now = datetime.now()
        month_start = int(datetime(now.year, now.month, 1).timestamp())
        if now.month == 12:
            month_end = int(datetime(now.year + 1, 1, 1).timestamp())
        else:
            month_end = int(datetime(now.year, now.month + 1, 1).timestamp())

        filters = json.dumps({"day": {"gte": month_start, "lte": month_end}}, separators=(",", ":"))
        url = (f"https://cloud.vast.ai/api/v0/charges/?"
               f"select_filters={quote(filters)}&latest_first=true&limit=50")
        charges = get(url, {"Authorization": f"Bearer {VASTAI_KEY}"})
        spent = sum(float(r.get("amount", 0)) for r in charges.get("results", []))
        if spent > 0:
            data["spent"] = spent
    except Exception:
        pass

    return data


# ── Exa ──────────────────────────────────────────────────────────────────

def get_exa():
    data = {"balance": None, "input": 0, "cached": 0, "output": 0,
            "spent": None, "models": OrderedDict()}
    if not EXA_SERVICE_KEY:
        return data

    headers = {"x-api-key": EXA_SERVICE_KEY}

    # 1. Discover API key ID
    try:
        keys_resp = get("https://admin-api.exa.ai/team-management/api-keys", headers)
        api_keys = keys_resp.get("apiKeys", [])
        if not api_keys:
            return data
        key_id = api_keys[0]["id"]
    except Exception:
        return data

    # 2. Fetch current month's usage
    try:
        now = datetime.now()
        start = f"{now.year}-{now.month:02d}-01T00:00:00Z"
        if now.month == 12:
            end = f"{now.year + 1}-01-01T00:00:00Z"
        else:
            end = f"{now.year}-{now.month + 1:02d}-01T00:00:00Z"
        params = f"start_date={start}&end_date={end}"
        url = (f"https://admin-api.exa.ai/team-management/api-keys/"
               f"{key_id}/usage?{params}")
        usage = get(url, headers)
        data["spent"] = float(usage.get("total_cost_usd", 0))
    except Exception:
        pass

    return data


# ── display ──────────────────────────────────────────────────────────────

PROVIDER_NAMES = {"deepseek": "DeepSeek", "xai": "xAI", "vastai": "Vast.ai", "exa": "Exa"}

def fmt_amt(n):
    if n is None: return "     —"
    return f"${n:,.2f}"

def fmt_tok(n):
    if n == 0: return "        —"
    return f"{n:>9,}"


def _select(providers):
    ds  = get_deepseek()
    xai = get_xai()
    va  = get_vastai()
    exa = get_exa()
    return [PROVIDER_NAMES[k] for k in ["deepseek", "xai", "vastai", "exa"]], [ds, xai, va, exa]


def _token_pcts(d):
    total_in = d["cached"] + d["input"]
    hit = round(d["cached"] / total_in * 100, 1) if total_in > 0 else 0
    miss = round(d["input"] / total_in * 100, 1) if total_in > 0 else 0
    return hit, miss


def _model_entry(d):
    hit, miss = _token_pcts(d)
    return {
        "tokens_in_hit": d["cached"],
        "tokens_in_hit_percentage": hit,
        "tokens_in_miss": d["input"],
        "tokens_in_miss_percentage": miss,
        "tokens_out": d["output"],
        "tokens_total": d["cached"] + d["input"] + d["output"],
    }


def render_json(providers, show_model=False):
    names, data = _select(providers)
    key_map = {"deepseek": "DeepSeek", "xai": "xAI", "vastai": "Vast.ai", "exa": "Exa"}
    out = {}
    for k in ["deepseek", "xai", "vastai", "exa"]:
        if k not in providers:
            continue
        d = {"deepseek": data[0], "xai": data[1], "vastai": data[2], "exa": data[3]}[k]
        entry = _model_entry(d)
        entry["balance"] = round(d["balance"], 2) if d["balance"] is not None else None
        entry["period_spend"] = round(d["spent"], 2) if d["spent"] is not None else None

        if show_model and d["models"]:
            entry["models"] = OrderedDict()
            for mname, md in d["models"].items():
                entry["models"][mname] = _model_entry(md)

        out[key_map[k].lower()] = entry
    print(json.dumps(out, indent=2))


def render_table(providers, show_model=False):
    names, data = _select(providers)
    key_map = {"deepseek": "DeepSeek", "xai": "xAI", "vastai": "Vast.ai", "exa": "Exa"}

    filtered_names = []
    filtered_data = []
    for k in ["deepseek", "xai", "vastai", "exa"]:
        if k in providers:
            filtered_names.append(key_map[k])
            filtered_data.append({"deepseek": data[0], "xai": data[1], "vastai": data[2], "exa": data[3]}[k])

    if not filtered_names:
        return

    token_labels = [
        "Tokens In (Cache Hit)",
        "Tokens In (Cache Miss)",
        "Tokens Out",
        "Tokens Total",
    ]

    total_rows = [
        ("Account Balance", lambda d: fmt_amt(d["balance"])),
        ("Period Spend",    lambda d: fmt_amt(d["spent"])),
        (token_labels[0],   lambda d: fmt_tok(d["cached"])),
        (token_labels[1],   lambda d: fmt_tok(d["input"])),
        (token_labels[2],   lambda d: fmt_tok(d["output"])),
        (token_labels[3],   lambda d: fmt_tok(d["cached"] + d["input"] + d["output"])),
    ]

    dw = 20
    label_w = max(len(r[0]) for r in total_rows)
    if show_model:
        for d in filtered_data:
            for mname in d["models"]:
                label_w = max(label_w, len(mname) + 2)

    # ── print totals ──
    print(f"{'':{label_w}}  " + "  ".join(n.center(dw) for n in filtered_names))
    print(f"{'─'*label_w}──" + "──".join("─"*dw for _ in filtered_names))
    for label, fn in total_rows:
        vals = [fn(d) for d in filtered_data]
        line = "  ".join(v.rjust(dw) for v in vals)
        print(f"{label:<{label_w}}  {line}")

    if not show_model:
        print()
        return

    print()

    # ── per-model sections ──
    provider_models = [list(d["models"].keys()) for d in filtered_data]
    max_models = max((len(m) for m in provider_models), default=0)

    model_fn = [
        lambda d: fmt_tok(d["cached"]),
        lambda d: fmt_tok(d["input"]),
        lambda d: fmt_tok(d["output"]),
        lambda d: fmt_tok(d["cached"] + d["input"] + d["output"]),
    ]

    for idx in range(max_models):
        model_names = []
        model_data_for_row = []
        for pi in range(len(filtered_data)):
            if idx < len(provider_models[pi]):
                model_names.append(f"[{provider_models[pi][idx]}]")
                model_data_for_row.append(filtered_data[pi]["models"][provider_models[pi][idx]])
            else:
                model_names.append("")
                model_data_for_row.append(_m())

        print(f"{'':{label_w}}  " + "  ".join(n.center(dw) for n in model_names))

        for li in range(4):
            vals = [model_fn[li](d) for d in model_data_for_row]
            line = "  ".join(v.rjust(dw) for v in vals)
            print(f"{token_labels[li]:<{label_w}}  {line}")
        print()


ALL_PROVIDERS = ["deepseek", "xai", "vastai", "exa"]


# ── cli ──────────────────────────────────────────────────────────────────

HELP_TEXT = """\
ai-usage-tool — cross-provider balance + token usage.

Fetch normalized account balance, period spend, and token breakdowns
from DeepSeek, xAI, Vast.ai, and Exa.  Reads credentials from ~/.hermes/.env.

Usage:
  ./get-data                          all providers (default)
  ./get-data -p xai                   single provider
  ./get-data -p deepseek,xai          multiple providers
  ./get-data -m                       per-model token breakdown
  ./get-data -j                       JSON output
  ./get-data -j -m -p deepseek        JSON with per-model models key
  ./get-data help                     this text

Options:
  -p, --provider DEEPSEEK,XAI,VASTAI,EXA  comma-separated (default: all four)
  -m, --model                         add per-model token rows below totals
  -j, --json                          machine-readable JSON output
  -h, --help                          this text

Output fields (table):
  Account Balance          credit remaining (USD)
  Period Spend             cost this billing cycle (USD)
  Tokens In (Cache Hit)    cached prompt tokens
  Tokens In (Cache Miss)   uncached prompt tokens
  Tokens Out               completion tokens
  Tokens Total             sum of all token types

Output fields (JSON):
  balance, period_spend, tokens_in_hit, tokens_in_hit_percentage,
  tokens_in_miss, tokens_in_miss_percentage, tokens_out, tokens_total
  With -m: adds "models" key with per-model breakdown.

Credentials (from ~/.hermes/.env):
  DEEPSEEK_API_KEY       standard API key
  DEEPSEEK_AUTH_TOKEN    platform session token (expires, see README)
  XAI_MANAGEMENT_KEY     xAI management API key
  XAI_TEAM_ID            xAI team UUID
  VASTAI_API_KEY         Vast.ai API key (or ~/.config/vastai/vast_api_key)
  EXA_SERVICE_KEY        Exa service key (from dashboard.exa.ai)\\
"""

if __name__ == "__main__":
    if len(sys.argv) > 1 and sys.argv[1] == "help":
        print(HELP_TEXT)
        sys.exit(0)

    p = argparse.ArgumentParser(
        description="Cross-provider balance + token usage.",
        usage="%(prog)s [-p PROVIDERS] [-m] [-j]",
        add_help=False)
    p.add_argument("--model", "-m", action="store_true", help=argparse.SUPPRESS)
    p.add_argument("--json", "-j", action="store_true", help=argparse.SUPPRESS)
    p.add_argument("--provider", "-p", default=",".join(ALL_PROVIDERS), help=argparse.SUPPRESS)
    p.add_argument("--help", "-h", action="store_true", help=argparse.SUPPRESS)
    args = p.parse_args()

    if args.help:
        print(HELP_TEXT)
        sys.exit(0)

    providers = [s.strip().lower() for s in args.provider.split(",") if s.strip()]
    for prov in providers:
        if prov not in ALL_PROVIDERS:
            print(f"Unknown provider: {prov}. Choices: {','.join(ALL_PROVIDERS)}", file=sys.stderr)
            sys.exit(1)

    if args.json:
        render_json(providers, show_model=args.model)
    else:
        render_table(providers, show_model=args.model)
