#!/usr/bin/env python3
"""
aiwatch — check credit balance across AI vendors.

Usage:
  aiwatch              Show all providers
  aiwatch xai          xAI only (tries browser cookies, then API key)
  aiwatch deepseek     DeepSeek only
  aiwatch vastai       Vast.ai only
  aiwatch --json       Machine-readable JSON output
  aiwatch --verbose    Detailed output

API keys read from environment:
  XAI_API_KEY, DEEPSEEK_API_KEY, VASTAI_API_KEY

xAI does not expose credit balance via its public API. This tool tries:
  1. Browser session cookie (Chrome/Firefox — you must be logged into console.x.ai)
  2. XAI_CONSOLE_TOKEN env var (manual session token)
  3. Falls back to dashboard link
"""

import datetime
import http.cookiejar
import json
import os
import sqlite3
import sys
import urllib.request
import urllib.error


# ─── helpers ─────────────────────────────────────────────────────────────────

def _http_get(url, headers=None, timeout=10):
    """GET request. Returns (status, body_dict_or_string)."""
    req = urllib.request.Request(url)
    if headers:
        for k, v in headers.items():
            req.add_header(k, v)
    try:
        with urllib.request.urlopen(req, timeout=timeout) as r:
            raw = r.read().decode()
            try:
                return r.status, json.loads(raw)
            except json.JSONDecodeError:
                return r.status, raw
    except urllib.error.HTTPError as e:
        body = e.read().decode()
        try:
            return e.code, json.loads(body)
        except json.JSONDecodeError:
            return e.code, body
    except urllib.error.URLError as e:
        return 0, {"error": str(e.reason)}
    except Exception as e:
        return 0, {"error": str(e)}


def _api_get(url, api_key, timeout=10):
    """GET with Bearer auth. Returns (status, body_dict)."""
    return _http_get(url, {
        "Authorization": f"Bearer {api_key}",
        "Content-Type": "application/json",
    }, timeout)


def _cookie_get(url, cookie_string, timeout=10):
    """GET with Cookie header. Returns (status, body_dict)."""
    return _http_get(url, {
        "Cookie": cookie_string,
        "Content-Type": "application/json",
        "Accept": "application/json",
    }, timeout)


def _fmt_balance(currency, amount):
    """Format a balance string."""
    symbol = {"CNY": "¥", "USD": "$"}.get(currency, currency + " ")
    try:
        return f"{symbol}{float(amount):,.2f}"
    except (ValueError, TypeError):
        return f"{symbol}{amount}"


# ─── browser cookie extraction ───────────────────────────────────────────────

# Common browser cookie DB locations (Linux + WSL Windows paths)
_COOKIE_PATHS = [
    # Chrome Linux
    ("Chrome", os.path.expanduser("~/.config/google-chrome/Default/Cookies")),
    ("Chrome", os.path.expanduser("~/.config/google-chrome/Default/Network/Cookies")),
    # Chromium Linux
    ("Chromium", os.path.expanduser("~/.config/chromium/Default/Cookies")),
    ("Chromium", os.path.expanduser("~/.config/chromium/Default/Network/Cookies")),
    # Firefox Linux
    ("Firefox", os.path.expanduser("~/.mozilla/firefox")),  # dir, find profile
    # Edge Linux
    ("Edge", os.path.expanduser("~/.config/microsoft-edge/Default/Cookies")),
    ("Edge", os.path.expanduser("~/.config/microsoft-edge/Default/Network/Cookies")),
]


def _find_firefox_cookie_db():
    """Find Firefox cookies.sqlite in profile directories."""
    base = os.path.expanduser("~/.mozilla/firefox")
    if not os.path.isdir(base):
        return None
    for d in os.listdir(base):
        if d.endswith(".default-release") or d.endswith(".default"):
            path = os.path.join(base, d, "cookies.sqlite")
            if os.path.isfile(path):
                return path
    return None


def _extract_console_cookie(db_path, domain="console.x.ai"):
    """Extract session cookies for a domain from a Chromium/Chrome cookie DB."""
    try:
        conn = sqlite3.connect(f"file:{db_path}?mode=ro&nolock=1", uri=True)
        cur = conn.cursor()
        # Chrome encrypts some cookies — try to get the encrypted_value, 
        # but prefer cookies where value is plaintext (not starting with 'v10'/'v11')
        cur.execute(
            "SELECT name, value, encrypted_value FROM cookies "
            "WHERE host_key LIKE ?",
            (f"%{domain}%",)
        )
        rows = cur.fetchall()
        conn.close()

        cookies = []
        for name, value, enc in rows:
            if value and not value.startswith("v1"):  # plaintext cookies
                cookies.append((name, value))
        return cookies
    except Exception:
        return []


def _extract_firefox_cookie(db_path, domain="console.x.ai"):
    """Extract session cookies from Firefox cookies.sqlite."""
    try:
        conn = sqlite3.connect(f"file:{db_path}?mode=ro", uri=True)
        cur = conn.cursor()
        cur.execute(
            "SELECT name, value FROM moz_cookies WHERE host LIKE ?",
            (f"%{domain}%",)
        )
        rows = cur.fetchall()
        conn.close()
        return [(name, value) for name, value in rows]
    except Exception:
        return []


def _get_browser_cookie():
    """Try to find a console.x.ai session cookie from any browser. Returns cookie_string or None."""
    for browser, path in _COOKIE_PATHS:
        if not os.path.exists(path):
            continue

        if browser == "Firefox" and os.path.isdir(path):
            path = _find_firefox_cookie_db()
            if not path:
                continue

        if "firefox" in path.lower() or path.endswith(".sqlite"):
            cookies = _extract_firefox_cookie(path)
        else:
            cookies = _extract_console_cookie(path)

        if cookies:
            return "; ".join(f"{name}={value}" for name, value in cookies)

    return None


# ─── providers ───────────────────────────────────────────────────────────────

def check_xai(api_key):
    """xAI — try browser cookies, then manual token, then fallback to link."""
    result = {
        "provider": "xAI",
        "dashboard": "https://console.x.ai/team/default/billing",
        "api_valid": False,
        "balance": None,
        "error": None,
        "method": "none",
    }

    # Method 1: Browser cookie extraction
    cookie = _get_browser_cookie()
    if cookie:
        status, body = _cookie_get("https://console.x.ai/api/team/billing", cookie)
        if status == 200:
            result["api_valid"] = True
            result["balance"] = body
            result["method"] = "browser-cookie"
            return result

    # Method 2: Manual XAI_CONSOLE_TOKEN env var
    token = os.environ.get("XAI_CONSOLE_TOKEN", "")
    if token:
        cookie_str = token if "=" in token else f"session={token}"
        status, body = _cookie_get("https://console.x.ai/api/team/billing", cookie_str)
        if status == 200:
            result["api_valid"] = True
            result["balance"] = body
            result["method"] = "manual-token"
            return result

    # Method 3: API key validation only (no balance API available)
    if not api_key:
        result["error"] = "XAI_API_KEY not set (and no browser session found)"
        return result

    status, body = _api_get("https://api.x.ai/v1/models", api_key)
    if status == 200:
        result["api_valid"] = True
        result["models_available"] = [
            m.get("id", "unknown") for m in body.get("data", [])
        ]
    elif status == 401:
        result["error"] = "Invalid API key"
    else:
        result["error"] = body.get("error", f"HTTP {status}")

    if not result.get("balance"):
        if result.get("api_valid"):
            result["error"] = "Credit check requires browser login at console.x.ai"
        elif not result.get("error"):
            result["error"] = "XAI_API_KEY not set — try setting it or login to console.x.ai"

    return result


def check_deepseek(api_key):
    """DeepSeek — check balance via /user/balance."""
    result = {
        "provider": "DeepSeek",
        "dashboard": "https://platform.deepseek.com/",
        "api_valid": False,
        "balance": None,
        "error": None,
    }

    if not api_key:
        result["error"] = "DEEPSEEK_API_KEY not set"
        return result

    status, body = _api_get("https://api.deepseek.com/user/balance", api_key)
    if status == 200:
        result["api_valid"] = True
        result["balance"] = body
    elif status == 401:
        result["error"] = "Invalid API key (401)"
    else:
        result["error"] = body.get("error", f"HTTP {status}")

    return result


def check_vastai(api_key):
    """Vast.ai — check credits via /users/current/."""
    result = {
        "provider": "Vast.ai",
        "dashboard": "https://cloud.vast.ai/billing/",
        "api_valid": False,
        "balance": None,
        "charges": None,
        "error": None,
    }

    if not api_key:
        result["error"] = "VASTAI_API_KEY not set"
        return result

    base = "https://console.vast.ai/api/v0"

    # Get user info (includes credit balance)
    status, user = _api_get(f"{base}/users/current/", api_key)
    if status == 200:
        result["api_valid"] = True
        result["balance"] = user
    elif status in (401, 403):
        result["error"] = "Invalid API key"
        return result
    else:
        result["error"] = user.get("error", f"HTTP {status}")
        return result

    # Fetch recent invoices
    status, invoices = _api_get(f"{base}/invoices", api_key)
    if status == 200 and isinstance(invoices, dict):
        inv_list = invoices.get("invoices", invoices.get("data", []))
        if isinstance(inv_list, list):
            result["charges"] = inv_list[:5]

    return result


# ─── display ─────────────────────────────────────────────────────────────────

def _box(text):
    """Draw a simple box header."""
    n = len(text) + 2
    return f"┌{'─' * n}┐\n│ {text} │\n└{'─' * n}┘"


def display_xai(result, verbose=False):
    print(_box("xAI"))
    if result.get("balance"):
        b = result["balance"]
        method = result.get("method", "?")
        # Try to find credit/balance fields in the response
        credit = _find_credit_field(b)
        if credit is not None:
            print(f"  Credits:  ${credit:,.2f}")
        elif verbose:
            print(f"  Raw:      {json.dumps(b)[:200]}")
        print(f"  Method:   {method}")
        if verbose:
            print(f"  Billing:  → {result['dashboard']}")
    elif result.get("api_valid"):
        print(f"  Status:   ✅ API key valid")
        print(f"  Credits:  Check browser → {result['dashboard']}")
        print(f"  Tip:      Login to console.x.ai in Chrome/Firefox for balance")
    elif result.get("error"):
        print(f"  Status:   ❌ {result['error']}")
        print(f"  Credits:  → {result['dashboard']}")
    if verbose and result.get("models_available"):
        models = ", ".join(result["models_available"])
        print(f"  Models:   {models}")
    print()


def _find_credit_field(obj, depth=0):
    """Recursively search for a credit/balance numeric field in a dict."""
    if depth > 3:
        return None
    if isinstance(obj, dict):
        for key in ("credit", "credits", "balance", "total_credits", "remaining"):
            if key in obj:
                try:
                    return float(obj[key])
                except (ValueError, TypeError):
                    pass
        for v in obj.values():
            r = _find_credit_field(v, depth + 1)
            if r is not None:
                return r
    elif isinstance(obj, list) and obj:
        return _find_credit_field(obj[0], depth + 1)
    return None


def display_deepseek(result, verbose=False):
    print(_box("DeepSeek"))
    if result["error"]:
        print(f"  Status:   ❌ {result['error']}")
    elif result["balance"]:
        print(f"  Status:   ✅ Connected")
        b = result["balance"]
        available = "✅ Available" if b.get("is_available") else "⚠️  Low"
        print(f"  Balance:  {available}")
        for info in b.get("balance_infos", []):
            ccy = info.get("currency", "???")
            total = _fmt_balance(ccy, info.get("total_balance", "0"))
            granted = _fmt_balance(ccy, info.get("granted_balance", "0"))
            topped = _fmt_balance(ccy, info.get("topped_up_balance", "0"))
            print(f"            {total}  (granted: {granted}, topped-up: {topped})")
    if verbose:
        print(f"  Usage:    → {result['dashboard']}")
        print(f"  Models:   deepseek-v4-pro, deepseek-v4-flash")
    elif result.get("error"):
        print(f"  Usage:    → {result['dashboard']}")
    print()


def display_vastai(result, verbose=False):
    print(_box("Vast.ai"))
    if result["error"]:
        print(f"  Status:   ❌ {result['error']}")
    elif result["api_valid"]:
        print(f"  Status:   ✅ Connected")
        b = result["balance"] or {}
        credit = b.get("credit", b.get("balance", b.get("total", "?")))
        if credit and credit != "?":
            try:
                print(f"  Credits:  ${float(credit):,.2f}")
            except (ValueError, TypeError):
                print(f"  Credits:  {credit}")

        charges = result.get("charges") or []
        if charges:
            print(f"  Recent charges ({len(charges)}):")
            for ch in charges[:5]:
                amt = ch.get("amount", ch.get("debit", ch.get("total", "?")))
                desc = ch.get("description", ch.get("type", ch.get("reason", "?")))
                ts = ch.get("timestamp", ch.get("date", ch.get("created", "")))
                if ts:
                    ts = ts[:10]
                try:
                    amt_str = f"${float(amt):,.2f}"
                except (ValueError, TypeError):
                    amt_str = str(amt)
                print(f"    {ts:10s} {amt_str:>10s}  {desc}")
    if verbose:
        print(f"  Billing:  → {result['dashboard']}")
    print()


def display_json(results):
    """Machine-readable JSON output."""
    print(json.dumps(results, indent=2, default=str))


# ─── main ────────────────────────────────────────────────────────────────────

def main():
    args = sys.argv[1:]
    providers = {"xai", "deepseek", "vastai", "all"}
    json_mode = "--json" in args
    verbose = "--verbose" in args or "-v" in args

    provider = "all"
    for a in args:
        if a in providers:
            provider = a
            break

    keys = {
        "xai": os.environ.get("XAI_API_KEY", ""),
        "deepseek": os.environ.get("DEEPSEEK_API_KEY", ""),
        "vastai": os.environ.get("VASTAI_API_KEY", ""),
    }

    # Detect WSL — add Windows Chrome paths
    if os.path.exists("/proc/sys/fs/binfmt_misc/WSLInterop"):
        import glob as _glob
        for users_dir in _glob.glob("/mnt/c/Users/*"):
            user = os.path.basename(users_dir)
            if user in ("Public", "Default", "All Users"):
                continue
            chrome_data = f"/mnt/c/Users/{user}/AppData/Local/Google/Chrome/User Data"
            if os.path.isdir(chrome_data):
                for profile in ("Default", "Profile 1", "Profile 2"):
                    net_cookies = f"{chrome_data}/{profile}/Network/Cookies"
                    old_cookies = f"{chrome_data}/{profile}/Cookies"
                    if os.path.isfile(net_cookies):
                        _COOKIE_PATHS.append(("Chrome-Win", net_cookies))
                    elif os.path.isfile(old_cookies):
                        _COOKIE_PATHS.append(("Chrome-Win", old_cookies))

    results = {}
    if provider in ("xai", "all"):
        results["xai"] = check_xai(keys["xai"])
    if provider in ("deepseek", "all"):
        results["deepseek"] = check_deepseek(keys["deepseek"])
    if provider in ("vastai", "all"):
        results["vastai"] = check_vastai(keys["vastai"])

    if json_mode:
        display_json(results)
    else:
        if "xai" in results:
            display_xai(results["xai"], verbose)
        if "deepseek" in results:
            display_deepseek(results["deepseek"], verbose)
        if "vastai" in results:
            display_vastai(results["vastai"], verbose)

        total = len(results)
        ok = sum(1 for r in results.values() if r.get("api_valid"))
        err = sum(1 for r in results.values() if r.get("error"))
        missing = sum(1 for r in results.values()
                      if r.get("error") and "not set" in str(r["error"]))
        print(f"─── {ok}/{total} providers OK, {err} errors ({missing} missing keys)")


if __name__ == "__main__":
    main()
